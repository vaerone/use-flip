{
  "name": "@vaerone/use-flip",
  "version": "1.0.0",
  "description": "React hooks for smooth FLIP animations — useFlip, useFlipGroup, FlipProvider",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "size": "size-limit"
  },
  "keywords": [
    "react",
    "flip",
    "animation",
    "layout",
    "transition",
    "typescript",
    "hooks"
  ],
  "license": "MIT",
  "author": {
    "name": "Ram Krishnan",
    "url": "https://github.com/vaerone"
  },
  "homepage": "https://github.com/vaerone/use-flip",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vaerone/use-flip.git"
  },
  "bugs": {
    "url": "https://github.com/vaerone/use-flip/issues"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@size-limit/preset-small-lib": "^11.0.0",
    "jsdom": "^24.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "size-limit": "^11.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "size-limit": [
    {
      "path": "dist/index.mjs",
      "limit": "3 kB"
    }
  ]
}
